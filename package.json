{
  "name": "chromium-browser",
  "version": "0.1.0",
  "description": "Chromium — High-performance Chromium browser shell",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "perf:benchmark": "node scripts/perf-benchmark.mjs",
    "test": "vitest",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json",
    "typecheck": "npm run typecheck:node && npm run typecheck:web"
  },
  "dependencies": {
    "@cliqz/adblocker-electron": "^1.34.0",
    "@ghostery/adblocker-electron": "^2.14.1",
    "@ghostery/adblocker-electron-preload": "^2.14.1",
    "cross-fetch": "^4.1.0",
    "motion": "^12.34.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.7.0",
    "electron": "github:castlabs/electron-releases#v33.4.11+wvcus",
    "electron-vite": "^5.0.0",
    "jsdom": "^28.1.0",
    "tailwindcss": "^4.1.0",
    "typescript": "^5.7.0",
    "vitest": "^4.0.18"
  }
}
